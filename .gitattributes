# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for these file types
*.kt text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.dockerfile text eol=lf
Dockerfile text eol=lf

# Force LF for gradlew (crucial for WSL/Linux execution)
gradlew text eol=lf
*.gradlew text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.zip binary
*.tar.gz binary
*.tgz binary

# Keep Windows line endings for batch files
*.bat text eol=crlf
*.cmd text eol=crlf